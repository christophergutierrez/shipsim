# Rust build output
/target

# Rustfmt backups
*.rs.bk

# Compiled shared libraries (shipsim_core is a cdylib; built artifact may be copied out)
*.so
*.dll
*.dylib

# Local scratch / caches (not part of the project)
/tmp
.fastembed_cache/

# LibreOffice lock files
.~lock.*#

# Frontend session scratch (also frontend/.gitignore and per-client .gitignore)
/frontend/**/local/

# Ephemeral session handoffs (local sticky notes; not product docs)
HANDOFF.md
**/HANDOFF.md

# Local-only agent pointer (points at tmp/ scratch; do not commit)
AGENT-LOCAL.md
**/AGENT-LOCAL.md

# Ephemeral UX/design scratch (local analysis; not product docs)
UX_ANALYSIS.md
**/UX_ANALYSIS.md

# IDE and tool artifacts
.claude/
.idea/
.vscode/
*.swp
*~

# OS artifacts
.DS_Store
Thumbs.db

# Ephemeral agent runtime state
.flocode/
.killhouse/
